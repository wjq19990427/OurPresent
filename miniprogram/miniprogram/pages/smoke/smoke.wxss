.page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, #f5f1e8 0%, #f8f7f3 38%, #ffffff 100%);
  color: #1f2933;
  box-sizing: border-box;
}

.hero,
.card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(69, 79, 91, 0.08);
  padding: 28rpx;
}

.card {
  margin-top: 24rpx;
}

.eyebrow {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #b16d3b;
}

.title {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #52606d;
}

.rerun {
  margin-top: 24rpx;
  background: #1f2933;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.meta,
.hint,
.detail {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #52606d;
}

.error-banner {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff1f2;
  color: #b42318;
  font-size: 24rpx;
  line-height: 1.5;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.row,
.suite-item {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(31, 41, 51, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
}

.pill,
.status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.ok,
.passed {
  background: #ecfdf3;
  color: #027a48;
}

.bad,
.failed {
  background: #fff1f2;
  color: #b42318;
}

.pending {
  background: #f2f4f7;
  color: #475467;
}

.suite-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}
