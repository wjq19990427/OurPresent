.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f4efe6 0%, #ffffff 100%);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #1f2933;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #52606d;
}

.cta {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #1f2933;
  color: #ffffff;
  font-size: 28rpx;
}
